# =============================================================
# Strapi 5 - Jtech CMS - Environment Variables
# =============================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# ⚠️  NUNCA comite o arquivo .env no repositório!
# =============================================================

# ---------------------------
# App Keys (obrigatório)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ---------------------------
APP_KEYS=CHANGE_ME_KEY1,CHANGE_ME_KEY2,CHANGE_ME_KEY3,CHANGE_ME_KEY4

# ---------------------------
# JWT Secrets (obrigatório)
# ---------------------------
API_TOKEN_SALT=CHANGE_ME_SALT
ADMIN_JWT_SECRET=CHANGE_ME_ADMIN_JWT
JWT_SECRET=CHANGE_ME_JWT

# ---------------------------
# Database (SQLite para dev, PostgreSQL para prod)
# ---------------------------
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Para produção com PostgreSQL, substitua por:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=jtech_strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
# DATABASE_SSL=false

# ---------------------------
# CORS - Origins permitidas (obrigatório em produção)
# Múltiplas: separar por vírgula
# ---------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---------------------------
# Preview Token
# Tempo de expiração em ms (padrão: 30 min)
# ---------------------------
PREVIEW_TOKEN_EXPIRATION=1800000

# ---------------------------
# Node Environment
# ---------------------------
NODE_ENV=development

# ---------------------------
# Host e Port (opcional)
# ---------------------------
HOST=0.0.0.0
PORT=1337

# ---------------------------
# AWS S3 - Upload de mídia (obrigatório em produção)
# Ativo automaticamente quando NODE_ENV=production
# ---------------------------
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_ACCESS_SECRET=CHANGE_ME
AWS_REGION=us-east-1
AWS_BUCKET=jtech-uploads
