{
  "kind": "collectionType",
  "collectionName": "ebooks",
  "info": {
    "singularName": "ebook",
    "pluralName": "ebooks",
    "displayName": "Ebook",
    "description": "Downloadable e-books and materials"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 150,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "pages": {
      "type": "integer",
      "min": 1,
      "default": 1
    },
    "category": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "downloadUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "ctaType": {
      "type": "enumeration",
      "enum": ["RD_FORM", "DIRECT_DOWNLOAD", "EXTERNAL_LINK"],
      "default": "RD_FORM",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "rdFormUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
